# CFGMS Local Development Configuration (Example)
# Copy this file to .env.local and fill in your Azure tenant values
#
# Setup Instructions:
# 1. Copy: cp .env.local.example .env.local
# 2. Fill in your Azure App Registration details below
# 3. Store secrets in OS keychain: ./scripts/migrate-credentials-to-keychain.sh
# 4. Load credentials: source ./scripts/load-credentials-from-keychain.sh

# M365 Dev Tenant Configuration
# Get these values from Azure Portal → App Registrations → Your App
M365_CLIENT_ID=your-azure-client-id-here
M365_CLIENT_SECRET=USE_KEYCHAIN  # Actual secret stored in OS keychain
M365_TENANT_ID=your-azure-tenant-id-here
M365_TENANT_DOMAIN=yourcompany.onmicrosoft.com
M365_INTEGRATION_ENABLED=true

# M365 MSP Tenant Configuration (Optional - for MSP scenarios)
M365_MSP_CLIENT_ID=your-msp-client-id-here
M365_MSP_CLIENT_SECRET=USE_KEYCHAIN  # Actual secret stored in OS keychain
M365_MSP_TENANT_ID=your-msp-tenant-id-here
M365_MSP_INTEGRATION_ENABLED=true

# Security Notes:
# - Client IDs and Tenant IDs are PUBLIC OAuth2 values (appear in URLs)
# - Client Secrets are PRIVATE and stored in OS keychain (encrypted)
# - Never commit .env.local to git (it's gitignored)
# - The keychain provides OS-level encryption for secrets

# How to get Azure credentials:
# 1. Go to https://portal.azure.com
# 2. Navigate to: Azure Active Directory → App Registrations
# 3. Create a new app or select existing app
# 4. Copy the Client ID and Tenant ID
# 5. Go to: Certificates & secrets → New client secret
# 6. Copy the secret value (shown only once!)
# 7. Store the secret in keychain using the migration script

# For more details, see: docs/security/README.md
