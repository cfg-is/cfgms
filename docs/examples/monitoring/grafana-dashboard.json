{
  "dashboard": {
    "id": null,
    "title": "CFGMS System Dashboard",
    "tags": ["cfgms", "monitoring"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "cfgms_stewards_connected",
            "legendFormat": "Connected Stewards"
          },
          {
            "expr": "cfgms_configurations_active",
            "legendFormat": "Active Configurations"
          },
          {
            "expr": "rate(cfgms_api_requests_total[5m])",
            "legendFormat": "API Requests/sec"
          }
        ],
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 2,
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cfgms_cpu_percent",
            "legendFormat": "Controller CPU %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 3,
        "title": "Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cfgms_memory_bytes",
            "legendFormat": "Controller Memory"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 4,
        "title": "Steward Connections",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cfgms_stewards_connected",
            "legendFormat": "Connected"
          },
          {
            "expr": "cfgms_stewards_disconnected",
            "legendFormat": "Disconnected"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
      },
      {
        "id": 5,
        "title": "Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(cfgms_api_requests_total[5m])",
            "legendFormat": "API Requests/sec"
          },
          {
            "expr": "rate(cfgms_grpc_requests_total[5m])",
            "legendFormat": "gRPC Requests/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
      },
      {
        "id": 6,
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(cfgms_errors_total[5m])",
            "legendFormat": "Errors/sec"
          },
          {
            "expr": "rate(cfgms_configuration_failures_total[5m])",
            "legendFormat": "Config Failures/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Response Times",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(cfgms_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(cfgms_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 8,
        "title": "Export Status",
        "type": "table",
        "targets": [
          {
            "expr": "cfgms_export_status",
            "legendFormat": "{{exporter}}",
            "format": "table"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true
              },
              "renameByName": {
                "Value": "Status",
                "exporter": "Exporter"
              }
            }
          }
        ]
      },
      {
        "id": 9,
        "title": "Certificate Expiry",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cfgms_certificate_expiry_days",
            "legendFormat": "Days until expiry"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "fieldConfig": {
          "defaults": {
            "unit": "d",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 30},
                {"color": "green", "value": 90}
              ]
            }
          }
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "name": "CFGMS Deployments",
          "datasource": "prometheus",
          "enable": true,
          "expr": "increase(cfgms_deployment_timestamp[1m])",
          "iconColor": "blue",
          "titleFormat": "Deployment",
          "textFormat": "CFGMS deployment detected"
        }
      ]
    },
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(cfgms_cpu_percent, instance)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    }
  }
}