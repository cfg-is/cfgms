# Binaries
bin/*
!bin/cfgms-wait-for-services
*.exe
*.exe~
*.dll
*.so
*.dylib

# Project binaries (built from cmd/ directories)
/cfgctl
/cfgcli
/controller
/steward

# Test binary, built with 'go test -c'
*.test

# Compiled test binaries
test-controller
test-steward
test-*

# Generated protobuf files in wrong location (should be in api/proto/)
/steward/

# Output of the go coverage tool
*.out

# Backup and temporary files
*.backup
*.bak
*.old
*.tmp
*.wip
*~

# Dependency directories
vendor/

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# Docker temporary files
.docker/

# OS specific files
.DS_Store
Thumbs.db

# Build artifacts
dist/

# Security scan results (auto-generated)
sarif-results/
*.sarif

# Certificate files and keys (auto-generated during runtime/testing)
certs/
*.pem
*.crt
*.key

# Configuration files that might contain sensitive data
config.yaml
*.env
.env.local

# Credentials directory
m365-test-creds/

# Claude Code local settings
.claude/settings.local.json

.obsidian/

# Test/development storage data
features/controller/**/data/
**/cfgms-storage/
test/integration/data/
test/integration/logs/
.env.test
docker-compose.test.override.yml

# SQLite database files
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
docs/product/v*-epic.md

# Security audit reports (WIP audit reports with unfixed vulnerabilities)
# Note: Remediation summaries and completed audits should be committed
docs/security/audits/*-wip.md
docs/security/audits/draft-*.md
